<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_stock">

    <fragment
        android:id="@+id/navigation_stock"
        android:name="com.example.journeytowealth.ui.mystock.stock.StockFragment"
        android:label="Index" />

    <fragment
        android:id="@+id/navigation_portfolio"
        android:name="com.example.journeytowealth.ui.mystock.portfolio.PortfolioFragment"
        android:label="PortFolio" />

    <fragment
        android:id="@+id/navigation_checklist"
        android:name="com.example.journeytowealth.ui.mystock.checklist.CheckListFragment"
        android:label="CheckList">
        <action
            android:id="@+id/action_checklist_to_detail"
            app:destination="@id/navigation_checklist_detail"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/navigation_checklist_detail"
        android:name="com.example.journeytowealth.ui.mystock.checklist.CheckListDetailFragment"
        android:label="CheckList Detail">

        <argument
            android:name="stockName"
            android:defaultValue="None"
            app:argType="string" />

        <argument
            android:name="type"
            android:defaultValue="ADD"
            app:argType="com.example.journeytowealth.ui.mystock.checklist.CHECKLISTTYPE" />
    </fragment>


    <fragment
        android:id="@+id/navigation_navPage"
        android:name="com.example.journeytowealth.ui.toprightmenu.navInfoPage.NavInfoPage"
        android:label="Macro Economics" >
        <action
            android:id="@+id/action_navPage_to_macro"
            app:destination="@id/navigation_macro_economics"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/navigation_macro_economics"
        android:name="com.example.journeytowealth.ui.toprightmenu.macroeconomic.MacroEconomicsFragment"
        android:label="Macro Economics" />
</navigation>