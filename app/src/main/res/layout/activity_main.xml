<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.main.MainActivity">

    <!-- Toolbar -->
    <include
        android:id="@+id/toolbar_main"
        layout="@layout/view_common_toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Fragment Container -->

    <!-- Bottom Navigation -->

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation_main"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_main"
        app:layout_constraintVertical_bias="1.0"
        app:navGraph="@navigation/nav_graph_main" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation_main"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/nav_bottom_main" />

    <!-- Toolbar 메뉴 -->
    <LinearLayout
        android:id="@+id/menu_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar_main">

        <TextView
            android:id="@+id/tv_login_toolbar_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_textview_border"
            android:gravity="center"
            android:minWidth="100dp"
            android:padding="10dp"
            android:text="Login"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tv_loading_data"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_textview_border"
            android:gravity="center"
            android:minWidth="100dp"
            android:padding="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="데이터 로딩"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tv_setting_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_textview_border"
            android:gravity="center"
            android:minWidth="100dp"
            android:padding="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="아직없음"
            android:textColor="@color/black" />


        <TextView
            android:id="@+id/tv_waiting2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_textview_border"
            android:gravity="center"
            android:minWidth="100dp"
            android:padding="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="아직없음"
            android:textColor="@color/black" />
    </LinearLayout>

    <!-- 로딩 -->
    <FrameLayout
        android:id="@+id/flLoadingContainerMain"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 로딩 카드 -->
        <LinearLayout
            android:layout_width="160dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="@drawable/bg_loading_card">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progressBarMaterial"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:indicatorColor="@color/loading_main"
                app:trackColor="#E5E5E5"
                app:trackThickness="5dp"/>

            <TextView
                android:id="@+id/tv_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Loading..."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#555555"/>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
